---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Sandeep Singh - Polymath Portfolio. Bridging software systems with geopolitical, economic, and governmental systems." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Sandeep Singh</title>
    <meta name="description" content={description} />
  </head>
  <body class="bg-dark-900 text-silver">
    
    <!-- Pulse Subtle Background Nodes -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
      <div class="absolute -top-[40%] -left-[20%] w-[80%] h-[80%] rounded-full bg-sovereign/5 blur-[120px] animate-pulse-subtle"></div>
      <div class="absolute -bottom-[40%] -right-[20%] w-[80%] h-[80%] rounded-full bg-cyber/5 blur-[120px] animate-pulse-subtle"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-transparent via-dark-950/20 to-dark-950 opacity-80"></div>
    </div>

    <!-- Header Navigation -->
    <header class="sticky top-0 z-50 glassmorphism border-b border-white/5 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        
        <!-- Logo / Brand -->
        <a href="/" class="flex items-center space-x-2 group">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-sovereign to-cyber flex items-center justify-center font-bold font-heading text-dark-950 transition-all duration-300 group-hover:rotate-12">
            S
          </div>
          <span class="font-heading font-semibold text-lg tracking-wider text-white group-hover:text-sovereign transition-colors duration-300">
            SANDEEP<span class="text-cyber">.SINGH</span>
          </span>
        </a>

        <!-- Desktop Nav Links -->
        <nav class="hidden md:flex items-center space-x-8">
          <a href="/" class="text-sm font-medium tracking-wide hover:text-sovereign transition-colors duration-200">Gateway</a>
          <a href="/about" class="text-sm font-medium tracking-wide hover:text-sovereign transition-colors duration-200">The Matrix</a>
          <a href="/#projects" class="text-sm font-medium tracking-wide hover:text-sovereign transition-colors duration-200">Projects</a>
          <a href="/ledger" class="text-sm font-medium tracking-wide hover:text-sovereign transition-colors duration-200">Thought Ledger</a>
          <a href="/#contact" class="btn-gold !px-4 !py-1.5 !rounded-md text-xs">Connect</a>
        </nav>

        <!-- Mobile Menu Toggle Button -->
        <button id="mobile-menu-toggle" class="md:hidden p-2 rounded-lg hover:bg-white/5 text-white focus:outline-none" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden md:hidden px-4 pt-2 pb-6 space-y-3 bg-dark-900 border-t border-white/5">
        <a href="/" class="block px-3 py-2 rounded-lg text-base font-medium hover:bg-white/5 hover:text-sovereign transition-colors duration-200">Gateway</a>
        <a href="/about" class="block px-3 py-2 rounded-lg text-base font-medium hover:bg-white/5 hover:text-sovereign transition-colors duration-200">The Matrix</a>
        <a href="/#projects" class="block px-3 py-2 rounded-lg text-base font-medium hover:bg-white/5 hover:text-sovereign transition-colors duration-200">Projects</a>
        <a href="/ledger" class="block px-3 py-2 rounded-lg text-base font-medium hover:bg-white/5 hover:text-sovereign transition-colors duration-200">Thought Ledger</a>
        <a href="/#contact" class="block text-center btn-gold !py-2.5">Connect</a>
      </div>
    </header>

    <!-- Main Content Container -->
    <main class="flex-grow z-10 relative max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="z-10 relative glassmorphism border-t border-white/5 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="font-heading text-lg font-semibold tracking-wider text-white mb-4">Sandeep Singh</h3>
            <p class="text-sm text-silver/60 leading-relaxed">
              Software Systems Engineer & Public Policy Analyst. Viewing software architectures and geopolitical networks through a single, unified lens.
            </p>
          </div>
          <div>
            <h3 class="font-heading text-sm font-semibold tracking-wider text-sovereign uppercase mb-4">Integrations</h3>
            <ul class="space-y-2 text-sm text-silver/70">
              <li><a href="/#projects" class="hover:text-white transition-colors duration-200">Portfolio Engine</a></li>
              <li><a href="/ledger" class="hover:text-white transition-colors duration-200">Thought Ledger (Writing)</a></li>
              <li><a href="/about" class="hover:text-white transition-colors duration-200">The Matrix (Interactive Bio)</a></li>
              <li><a href="mailto:singh.sandeep6537@gmail.com" class="hover:text-white transition-colors duration-200">Direct Email</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-heading text-sm font-semibold tracking-wider text-cyber uppercase mb-4">Philosophy</h3>
            <p class="text-xs text-silver/50 leading-relaxed italic">
              "The constant friction between powers is not an anomaly; it is the system maintaining equilibrium. Consensus in systems design represents constitutional quorum."
            </p>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between text-xs text-silver/40">
          <p>&copy; {new Date().getFullYear()} Sandeep Singh. All rights reserved.</p>
          <div class="flex space-x-6 mt-4 sm:mt-0">
            <span>Location: Punjab, India</span>
            <span>BE in Computer Engineering (TIET)</span>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle script
      const btn = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const icon = document.getElementById('menu-icon');

      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
        
        if (menu?.classList.contains('hidden')) {
          icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        } else {
          icon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
        }
      });
    </script>
  </body>
</html>
