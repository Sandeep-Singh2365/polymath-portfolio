---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projectsData from '../../data/projects_audit.json';

export async function getStaticPaths() {
  return Object.keys(projectsData).map((slug) => {
    return {
      params: { slug },
      props: { project: projectsData[slug as keyof typeof projectsData] },
    };
  });
}

const { slug } = Astro.params;
const { project } = Astro.props;

// Determine category accent coloring
const isFullStack = project.category === 'Full-Stack';
const isDataScience = project.category === 'Data Science & ML';

const textAccent = isFullStack ? 'text-cyber' : isDataScience ? 'text-sovereign' : 'text-purple-400';
const bgAccent = isFullStack ? 'bg-cyber/10 text-cyber border-cyber/20' : isDataScience ? 'bg-sovereign/10 text-sovereign border-sovereign/20' : 'bg-purple-500/10 text-purple-400 border-purple-500/20';
const borderAccent = isFullStack ? 'border-cyber/30' : isDataScience ? 'border-sovereign/30' : 'border-purple-500/30';
const shadowAccent = isFullStack ? 'shadow-[0_0_30px_rgba(16,185,129,0.05)]' : isDataScience ? 'shadow-[0_0_30px_rgba(212,175,55,0.05)]' : 'shadow-[0_0_30px_rgba(168,85,247,0.05)]';

const filenames = Object.keys(project.highlights);
---

<BaseLayout title={`${project.title} | Architecture`} description={project.description}>
  <div class="space-y-12">
    
    <!-- Back Navigation -->
    <div>
      <a href="/" class="inline-flex items-center space-x-2 text-xs font-heading font-semibold text-silver/40 hover:text-sovereign tracking-wider transition-colors duration-200 group">
        <svg class="w-4 h-4 transform transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <span>BACK_TO_GATEWAY()</span>
      </a>
    </div>

    <!-- Project Header -->
    <div class="space-y-4 border-b border-white/5 pb-8">
      <div class="flex items-center space-x-3">
        <span class={`text-[10px] font-heading uppercase tracking-wider px-2 py-0.5 rounded border ${bgAccent}`}>
          {project.category}
        </span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold font-heading text-white">
        {project.title}
      </h1>
      <p class="text-base sm:text-lg text-silver/70 max-w-4xl leading-relaxed">
        {project.description}
      </p>
    </div>

    <!-- Main Workspace Section: Code Console & Metrics Split -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Code Console Column (2/3 width) -->
      <div class="lg:col-span-2 space-y-6">
        
        <!-- Tabbed Code Auditor Box -->
        <div class={`glassmorphism rounded-xl border ${borderAccent} ${shadowAccent} overflow-hidden`}>
          
          <!-- Code Title Bar -->
          <div class="bg-dark-950 px-4 py-3 border-b border-white/5 flex items-center justify-between flex-wrap gap-3">
            <div class="flex items-center space-x-2">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
              <span class="text-xs font-mono text-silver/40 pl-2">CODE_AUDITOR_CONSOLE</span>
            </div>
            
            <!-- File Tabs -->
            <div class="flex space-x-1">
              {filenames.map((fname, idx) => (
                <button 
                  data-file={fname}
                  class={`code-tab px-3 py-1 rounded text-xs font-mono transition-all duration-300 focus:outline-none ${idx === 0 ? 'bg-dark-800 text-sovereign border border-white/10' : 'text-silver/50 hover:text-white'}`}
                >
                  {fname}
                </button>
              ))}
            </div>
          </div>

          <!-- Code Content Display -->
          <div class="p-6 bg-dark-950 overflow-x-auto min-h-[350px] max-h-[500px]">
            {filenames.map((fname, idx) => (
              <pre 
                id={`code-block-${fname}`} 
                class={`code-content font-mono text-xs text-silver/90 leading-relaxed ${idx === 0 ? 'block' : 'hidden'}`}
              >
                <code>{project.highlights[fname]}</code>
              </pre>
            ))}
          </div>

        </div>

        <!-- Architectural deep dive card -->
        <div class="glassmorphism rounded-xl p-6 border border-white/5 space-y-4">
          <h3 class="text-lg font-heading font-semibold text-white tracking-wide">
            Architectural Specification
          </h3>
          <p class="text-sm text-silver/70 leading-relaxed">
            {project.architecture_summary}
          </p>
        </div>

      </div>

      <!-- Repo Metadata & File Tree Column (1/3 width) -->
      <div class="space-y-6">
        
        <!-- Repo Overview Metadata -->
        <div class="glassmorphism rounded-xl p-6 border border-white/5 space-y-6">
          <h3 class="text-lg font-heading font-semibold text-white tracking-wide border-b border-white/5 pb-3">
            System Specs
          </h3>
          <div class="space-y-4 text-xs font-mono">
            <div>
              <div class="text-silver/40 uppercase mb-1">Project Name</div>
              <div class="text-white text-sm font-semibold">{project.title}</div>
            </div>
            <div>
              <div class="text-silver/40 uppercase mb-1">Domain Class</div>
              <div class="text-white text-sm font-semibold">{project.category}</div>
            </div>
            <div>
              <div class="text-silver/40 uppercase mb-1">Architecture Style</div>
              <div class="text-white text-sm font-semibold">Modular, Structured</div>
            </div>
            <div>
              <div class="text-silver/40 uppercase mb-1">Integrations Count</div>
              <div class="text-white text-sm font-semibold">{Object.keys(project.highlights).length} Key Modules</div>
            </div>
          </div>
        </div>

        <!-- File Tree Box -->
        <div class="glassmorphism rounded-xl p-6 border border-white/5 space-y-4">
          <h3 class="text-lg font-heading font-semibold text-white tracking-wide border-b border-white/5 pb-3">
            Audited File Tree
          </h3>
          <div class="p-4 bg-dark-950 rounded-lg border border-white/5 overflow-y-auto max-h-[300px]">
            <pre class="font-mono text-[11px] text-silver/70 leading-relaxed"><code>{project.file_tree}</code></pre>
          </div>
        </div>

      </div>

    </div>

  </div>

  <script>
    const tabs = document.querySelectorAll('.code-tab');
    const contents = document.querySelectorAll('.code-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetFile = tab.getAttribute('data-file');

        // Swap tab styles
        tabs.forEach(t => {
          if (t === tab) {
            t.classList.add('bg-dark-800', 'text-sovereign', 'border', 'border-white/10');
            t.classList.remove('text-silver/50');
          } else {
            t.classList.remove('bg-dark-800', 'text-sovereign', 'border', 'border-white/10');
            t.classList.add('text-silver/50');
          }
        });

        // Swap displayed content block
        contents.forEach(content => {
          const contentId = content.getAttribute('id');
          if (contentId === `code-block-${targetFile}`) {
            content.classList.remove('hidden');
            content.classList.add('block');
          } else {
            content.classList.remove('block');
            content.classList.add('hidden');
          }
        });
      });
    });
  </script>
</BaseLayout>
