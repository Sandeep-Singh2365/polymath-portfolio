---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Transmission Completed">
  <div class="max-w-md mx-auto py-16 text-center space-y-8 animate-fade-in">
    
    <!-- Success Orb -->
    <div class="relative w-36 h-36 mx-auto">
      <div class="absolute inset-0 rounded-full border border-cyber/30 animate-[spin_20s_linear_infinite]"></div>
      <div class="absolute inset-2 rounded-full bg-cyber/10 filter blur-md"></div>
      <div class="absolute inset-6 rounded-full bg-dark-800 border border-cyber/50 flex items-center justify-center">
        <svg class="w-12 h-12 text-cyber" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>

    <!-- Success Messaging -->
    <div class="space-y-3">
      <h1 class="text-3xl font-extrabold font-heading text-white">
        Transmission <span class="text-gradient-cyber">Completed</span>
      </h1>
      <p class="text-sm text-silver/60 leading-relaxed max-w-sm mx-auto">
        Your message has been successfully committed to the database. The system consensus has acknowledged the write.
      </p>
    </div>

    <!-- System specs simulation -->
    <div class="p-4 rounded-lg border border-white/5 bg-dark-950/40 text-left font-mono text-[10px] text-silver/50 space-y-1">
      <div>&gt; status: 200_ok</div>
      <div>&gt; target: form_contact</div>
      <div>&gt; response: committed_successfully</div>
      <div>&gt; timestamp: {new Date().toISOString()}</div>
    </div>

    <!-- Call to actions -->
    <div class="pt-4">
      <a href="/" class="btn-outline text-xs">RETURN_TO_GATEWAY</a>
    </div>

  </div>
</BaseLayout>
