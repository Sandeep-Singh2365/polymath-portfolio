---
// ProjectExplorer.astro
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: "Parantha House",
    description: "Full-stack serverless e-commerce ordering engine built with PostgreSQL and Netlify serverless functions. Integrates secure JWT authentication, direct Razorpay payment gateway APIs, and seeding/migration scripts.",
    tags: ["Node.js", "PostgreSQL", "Netlify Functions", "Razorpay", "JWT", "Vanilla JS", "Vanilla CSS"],
    category: "Full-Stack" as const,
    slug: "parantha-house"
  },
  {
    title: "WhatsApp Chat Analyzer",
    description: "Pandas and Streamlit natural language processing insight engine. Parses exported chat logs to model timelines, busiest user clusters, weekly activity maps, StopWords-filtered word clouds, and emoji densities.",
    tags: ["Python", "Streamlit", "Pandas", "Matplotlib", "Seaborn", "NLP", "Regex"],
    category: "Data Science & ML" as const,
    slug: "whatsapp-chat-analyzer"
  },
  {
    title: "Sudoku App",
    description: "Multi-tier interactive puzzle generator, validator, and backtracking-based solver engine built with a modular React client interface and a lightweight Node.js/Express backend server.",
    tags: ["React", "Node.js", "Express", "JavaScript", "Algorithms", "Concurrently"],
    category: "Full-Stack" as const,
    slug: "sudoku-app"
  },
  {
    title: "Swim Club Webapp",
    description: "SQL-driven database connection-managed Flask web application. Automatically processes swimmer time logs, executes database transaction queries via custom context managers, and generates dynamic inline SVG charts.",
    tags: ["Python", "Flask", "SQLite", "SQL", "SVG Charts", "Jinja2"],
    category: "Data Science & ML" as const,
    slug: "swimclub-webapp"
  },
  {
    title: "Movie Recommender System",
    description: "Content-based machine learning recommender application utilizing cosine-similarity algorithms on TMDB movie metadata. Serialized via Pickle and served through a clean, responsive Streamlit interface.",
    tags: ["Python", "Streamlit", "Machine Learning", "Pandas", "Pickle", "TMDB API"],
    category: "Data Science & ML" as const,
    slug: "movie-recommender"
  },
  {
    title: "Snake & Apple Game",
    description: "Core Pygame-driven desktop arcade game highlighting synchronous game loops, custom pixel-bounding collision mathematics, real-time keyboard event polling, score caches, and frame-rate clocks.",
    tags: ["Python", "Pygame", "Game Loop", "Desktop GUI", "File Storage"],
    category: "Systems & Games" as const,
    slug: "snake-and-apple"
  }
];

const categories = ["All", "Full-Stack", "Data Science & ML", "Systems & Games"];
---

<section id="projects" class="py-12 scroll-mt-20">
  <div class="space-y-8">
    
    <!-- Title & Filtering Nav -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-white/5 pb-6">
      <div class="space-y-2">
        <h2 class="text-3xl font-extrabold font-heading text-white">
          Architectural <span class="text-gradient-gold">Builds</span>
        </h2>
        <p class="text-sm text-silver/60 max-w-xl">
          A dynamic portfolio showcasing full-stack payment engines, machine learning recommender systems, relational databases, and low-level game loops.
        </p>
      </div>

      <!-- Filter Tabs -->
      <div class="flex flex-wrap gap-2">
        {categories.map(cat => (
          <button 
            data-filter={cat}
            class="filter-btn px-4 py-1.5 rounded-full text-xs font-heading font-medium tracking-wider border border-white/5 bg-dark-800/40 text-silver/70 transition-all duration-300 hover:border-sovereign/30 focus:outline-none"
          >
            {cat.toUpperCase()}
          </button>
        ))}
      </div>
    </div>

    <!-- Grid Container -->
    <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 transition-all duration-500">
      {projects.map(proj => (
        <div class="project-item-wrapper animate-fade-in" data-category={proj.category}>
          <ProjectCard 
            title={proj.title}
            description={proj.description}
            tags={proj.tags}
            category={proj.category}
            slug={proj.slug}
          />
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.project-item-wrapper');

  function filterCategory(activeCategory: string) {
    // Button state styling update
    buttons.forEach(btn => {
      const btnFilter = btn.getAttribute('data-filter');
      if (btnFilter === activeCategory) {
        btn.classList.add('bg-sovereign', 'text-dark-950', 'border-sovereign', 'shadow-[0_0_10px_rgba(212,175,55,0.2)]');
        btn.classList.remove('bg-dark-800/40', 'text-silver/70', 'border-white/5');
      } else {
        btn.classList.remove('bg-sovereign', 'text-dark-950', 'border-sovereign', 'shadow-[0_0_10px_rgba(212,175,55,0.2)]');
        btn.classList.add('bg-dark-800/40', 'text-silver/70', 'border-white/5');
      }
    });

    // Toggle grid items
    items.forEach(item => {
      const itemCategory = item.getAttribute('data-category');
      if (activeCategory === 'All' || itemCategory === activeCategory) {
        (item as HTMLElement).style.display = 'block';
        item.classList.add('animate-fade-in');
      } else {
        (item as HTMLElement).style.display = 'none';
        item.classList.remove('animate-fade-in');
      }
    });
  }

  // Click events
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter') || 'All';
      filterCategory(filter);
    });
  });

  // Init filter all active
  filterCategory('All');
</script>
