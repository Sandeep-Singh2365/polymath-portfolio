---
// ProjectCard.astro
interface Props {
  title: string;
  description: string;
  tags: string[];
  category: 'Full-Stack' | 'Data Science & ML' | 'Systems & Games';
  githubUrl?: string;
  slug: string;
}

const { title, description, tags, category, githubUrl = "#", slug } = Astro.props;

// Determine category border color
const accentColor = 
  category === 'Full-Stack' ? 'border-t-cyber hover:border-cyber/50' :
  category === 'Data Science & ML' ? 'border-t-sovereign hover:border-sovereign/50' :
  'border-t-purple-500 hover:border-purple-500/50';

const labelBg = 
  category === 'Full-Stack' ? 'bg-cyber/10 text-cyber border-cyber/20' :
  category === 'Data Science & ML' ? 'bg-sovereign/10 text-sovereign border-sovereign/20' :
  'bg-purple-500/10 text-purple-400 border-purple-500/20';
---

<div class={`interactive-card flex flex-col justify-between border-t-2 ${accentColor} h-full`}>
  <div class="space-y-4">
    <!-- Category Label & Header -->
    <div class="flex items-center justify-between">
      <span class={`text-[10px] uppercase tracking-wider px-2 py-0.5 rounded border font-heading ${labelBg}`}>
        {category}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-xl font-bold tracking-wide text-white group-hover:text-sovereign transition-colors duration-300">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-silver/60 leading-relaxed min-h-[72px]">
      {description}
    </p>

    <!-- Tech Stack Badges -->
    <div class="flex flex-wrap gap-1.5 pt-2">
      {tags.map(tag => (
        <span class="text-[10px] font-mono bg-dark-700 text-silver/80 px-2 py-0.5 rounded">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between pt-6 mt-6 border-t border-white/5">
    <a 
      href={`/projects/${slug}`} 
      class="text-xs font-heading font-semibold text-sovereign hover:text-gold-light tracking-wider flex items-center space-x-1"
    >
      <span>VIEW_ARCHITECTURE()</span>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
    
    {githubUrl && (
      <a 
        href={githubUrl} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-silver/40 hover:text-white transition-colors duration-200"
        title="View Repository"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
      </a>
    )}
  </div>
</div>
