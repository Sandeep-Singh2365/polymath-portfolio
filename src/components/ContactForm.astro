---
// ContactForm.astro
---

<section id="contact" class="py-16 scroll-mt-20 border-t border-white/5">
  <div class="max-w-4xl mx-auto space-y-12">
    
    <!-- Section Header -->
    <div class="text-center space-y-3">
      <h2 class="text-3xl font-extrabold font-heading text-white">
        Establish <span class="text-gradient-gold">Connection</span>
      </h2>
      <p class="text-sm text-silver/60 max-w-xl mx-auto">
        Have an engineering opportunity, custom API architectural challenge, or a deep intellectual point of discussion? Drop a line to establish connection.
      </p>
    </div>

    <!-- Contact Info + Form Split -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
      
      <!-- Info Column -->
      <div class="md:col-span-2 space-y-6">
        
        <!-- Info Card -->
        <div class="glassmorphism p-6 rounded-xl border border-white/5 space-y-6">
          <h3 class="text-lg font-heading font-semibold text-white">Direct Coordinates</h3>
          
          <div class="space-y-4">
            <!-- Email Coordinate -->
            <div class="flex items-start space-x-3 text-sm">
              <svg class="w-5 h-5 text-sovereign mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <div class="font-semibold text-white">EMAIL_ADDRESS</div>
                <a href="mailto:singh.sandeep6537@gmail.com" class="text-silver/60 hover:text-sovereign transition-colors duration-200">
                  singh.sandeep6537@gmail.com
                </a>
              </div>
            </div>

            <!-- Phone Coordinate -->
            <div class="flex items-start space-x-3 text-sm">
              <svg class="w-5 h-5 text-cyber mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div>
                <div class="font-semibold text-white">PHONE_NUMBER</div>
                <a href="tel:+919888606565" class="text-silver/60 hover:text-cyber transition-colors duration-200">
                  +91 98886 06565
                </a>
              </div>
            </div>

            <!-- Location Coordinate -->
            <div class="flex items-start space-x-3 text-sm">
              <svg class="w-5 h-5 text-purple-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <div class="font-semibold text-white">SYSTEM_LOCALE</div>
                <span class="text-silver/60">Batala, Punjab, India</span>
              </div>
            </div>
          </div>
        </div>

        <!-- System Assurances -->
        <div class="p-6 rounded-xl border border-white/5 bg-dark-800/10 space-y-2 text-xs text-silver/40">
          <p class="font-mono">&gt; connection: secure_ssl</p>
          <p class="font-mono">&gt; forms_server: serverless_action</p>
          <p class="font-mono">&gt; spam_filter: activated</p>
        </div>

      </div>

      <!-- Form Column -->
      <div class="md:col-span-3">
        <form 
          name="contact" 
          method="POST" 
          action="/success"
          data-netlify="true" 
          class="glassmorphism p-6 sm:p-8 rounded-xl border border-white/5 space-y-6"
        >
          <!-- Hidden form fields for Netlify/Vercel Forms -->
          <input type="hidden" name="form-name" value="contact" />

          <!-- Name -->
          <div class="space-y-2">
            <label for="form-name-field" class="block font-heading text-xs font-semibold tracking-wider text-white uppercase">
              Full Name
            </label>
            <input 
              type="text" 
              name="name" 
              id="form-name-field" 
              required 
              placeholder="Sandeep Singh" 
              class="w-full bg-dark-900 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-silver/30 focus:outline-none focus:border-sovereign transition-colors duration-300"
            />
          </div>

          <!-- Email -->
          <div class="space-y-2">
            <label for="form-email-field" class="block font-heading text-xs font-semibold tracking-wider text-white uppercase">
              Email Address
            </label>
            <input 
              type="email" 
              name="email" 
              id="form-email-field" 
              required 
              placeholder="singh.sandeep6537@gmail.com" 
              class="w-full bg-dark-900 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-silver/30 focus:outline-none focus:border-sovereign transition-colors duration-300"
            />
          </div>

          <!-- Subject -->
          <div class="space-y-2">
            <label for="form-subject-field" class="block font-heading text-xs font-semibold tracking-wider text-white uppercase">
              Connection Subject
            </label>
            <select 
              name="subject" 
              id="form-subject-field" 
              class="w-full bg-dark-900 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-sovereign transition-colors duration-300"
            >
              <option value="Professional Engineering Opportunities">Professional Engineering Opportunities</option>
              <option value="Geopolitical or Economic Dialogue">Geopolitical or Economic Dialogue</option>
              <option value="General Systems Query">General Systems Query</option>
            </select>
          </div>

          <!-- Message -->
          <div class="space-y-2">
            <label for="form-message-field" class="block font-heading text-xs font-semibold tracking-wider text-white uppercase">
              Transmission Message
            </label>
            <textarea 
              name="message" 
              id="form-message-field" 
              required 
              rows="5" 
              placeholder="Enter details of your proposed collaboration or systems discussion..." 
              class="w-full bg-dark-900 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-silver/30 focus:outline-none focus:border-sovereign transition-colors duration-300 resize-none"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <div class="pt-2">
            <button 
              type="submit" 
              class="w-full btn-gold !py-3 rounded-lg text-sm flex items-center justify-center space-x-2"
            >
              <span>TRANSMIT_MESSAGE()</span>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </button>
          </div>

        </form>
      </div>

    </div>

  </div>
</section>
